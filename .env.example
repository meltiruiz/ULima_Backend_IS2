# Conexión a PostgreSQL. Reemplazar host, usuario y contraseña por los reales (no commitear el .env real).
DATABASE_URL=postgresql://USER:PASSWORD@DB_HOST:5432/postgres?sslmode=require
# Secreto para firmar el JWT. Mínimo 8 caracteres; usar un valor largo y aleatorio en producción.
JWT_SECRET=your-super-secret-jwt-key
# Expiración del JWT en segundos (opcional, default 86400 = 24h).
JWT_EXPIRES_IN=86400
PORT=3000
NODE_ENV=development
# Orígenes permitidos para CORS, separados por coma (opcional). Vacío = permisivo (*). Definir en producción.
# Ejemplo: CORS_ORIGINS=https://ulimaplus.app,https://www.ulimaplus.app
CORS_ORIGINS=
# Clave de API de Resend (https://resend.com) para enviar correos de restablecimiento de contraseña.
# Si está vacía y NODE_ENV != production, el OTP se loguea en consola con prefijo [DEV ONLY] (no se envía correo).
RESEND_API_KEY=
# Remitente de los correos transaccionales, formato "Nombre <correo@dominio-verificado>".
RESEND_FROM=ULima+ <onboarding@resend.dev>

# Máximo de códigos de restablecimiento por usuario por hora (default 3).
# Subir solo temporalmente para QA; volver a 3 (o quitar) en producción normal.
PASSWORD_RESET_MAX_PER_HOUR=3

# Firebase Admin SDK para HU25 (chat en vivo). Copiar desde el JSON de Service Account
# y configurar también en Vercel como secretos. FIREBASE_PRIVATE_KEY debe conservar
# los saltos de línea escapados como \n, no se commitea el .env real.
FIREBASE_PROJECT_ID=ulima-plus-chat
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@ulima-plus-chat.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_DATABASE_URL=https://ulima-plus-chat-default-rtdb.firebaseio.com
